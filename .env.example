# Gemini API Key
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
MONGODB_DB_NAME=rocketium_2

# Optional capsule proxy endpoint (local tunnel / AWS Lambda / internal backend)
CAPSULE_LOOKUP_BASE_URL=https://your-app.example.com
CAPSULE_LOOKUP_TOKEN=your_proxy_shared_secret
CAPSULE_PROXY_KEY=your_proxy_shared_secret
CAPSULE_PROXY_PORT=8787
